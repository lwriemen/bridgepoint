	"9240490e-d66b-4111-b89d-3e937776a0ed");
INSERT INTO SM_ACT
	VALUES ("13f5e233-b319-4dc9-bce1-8a4443956ce3",
	"9240490e-d66b-4111-b89d-3e937776a0ed",
	1,
	'select any element from instances of GD_EOM where selected.elementId == rcvd_evt.element;
select one selection_tool related by element->CT_SEL[R110];
select one selection related by element->CT_CSL[R110];
unrelate self from selection across R111;
unrelate element from selection_tool across R110 using selection;
delete object instance selection;
select any selections related by self->CT_CSL[R111];
if (empty selections)
  generate CT_SSL3:delete_set to self;
end if;',
	'',
	0);
