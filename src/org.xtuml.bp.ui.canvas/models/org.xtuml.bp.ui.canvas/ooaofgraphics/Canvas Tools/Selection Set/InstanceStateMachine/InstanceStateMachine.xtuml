	VALUES ("2f37586f-f23d-4857-9d40-e8c26ece8b1b",
	"9240490e-d66b-4111-b89d-3e937776a0ed",
	"4f9e0873-19d8-449b-a3e5-ac8c933e2d82");
INSERT INTO SM_AH
	VALUES ("2f37586f-f23d-4857-9d40-e8c26ece8b1b",
	"9240490e-d66b-4111-b89d-3e937776a0ed");
INSERT INTO SM_ACT
	VALUES ("2f37586f-f23d-4857-9d40-e8c26ece8b1b",
	"9240490e-d66b-4111-b89d-3e937776a0ed",
	1,
	'select one action related by self->CT_SAT[R112];
if (not empty action)
  // This action language executes on an abnormal termination of action.
  select one cut related by action->CT_CUT[R113];
  if (not empty cut)
    unrelate action from cut across R113;
    delete object instance cut;
  else
    select one copy related by action->CT_CPY[R113];
    if (not empty copy)
      unrelate copy from action across R113;
      delete object instance copy;
    else
      select one drag related by action->CT_DRG[R113];
      if (not empty drag)
        unrelate drag from action across R113;
        delete object instance drag;
      else
        select one resize related by action->CT_RSZ[R113];
        if (not empty resize)
          unrelate resize from action across R113;
          delete object instance resize; 
        else
          select one paste related by action->CT_PST[R113];
          unrelate paste from action across R113;
          delete object instance paste;
        end if;
      end if;
    end if;
  end if;
  unrelate self from action across R112;
end if;',
	'',
	0);
