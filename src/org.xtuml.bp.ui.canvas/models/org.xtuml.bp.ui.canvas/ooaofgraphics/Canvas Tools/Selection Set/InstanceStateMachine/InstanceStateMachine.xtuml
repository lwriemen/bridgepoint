	"9240490e-d66b-4111-b89d-3e937776a0ed",
	1,
	'// Create association
select any selection_tool from instances of CT_SEL;
select any graphical_element from instances of GD_EOM where selected.elementId == rcvd_evt.element;
create object instance selection of CT_CSL;
relate selection_tool to graphical_element across R110 using selection;
relate self to selection across R111;',
	'',
	0);
