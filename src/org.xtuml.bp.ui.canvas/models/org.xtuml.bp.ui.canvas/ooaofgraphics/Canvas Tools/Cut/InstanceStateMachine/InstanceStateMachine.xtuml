INSERT INTO O_OBJ_PROXY
	VALUES ("e7ac1286-3db4-435f-b3dc-78484b6da7a0",
	'Cut',
	110,
	'CT_CUT',
	'A cut will delete the selected elements from all visible views. The cut 
elements will be availiable for pasting.
