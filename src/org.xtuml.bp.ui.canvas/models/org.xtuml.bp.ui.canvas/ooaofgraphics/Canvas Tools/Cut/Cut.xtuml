INSERT INTO O_OBJ
	VALUES ("e7ac1286-3db4-435f-b3dc-78484b6da7a0",
	'Cut',
	110,
	'CT_CUT',
	'A cut will delete the selected elements from all visible views. The cut 
elements will be availiable for pasting.
    A cut without a paste is the same as a delete. The decision for retention 
of the selection on a stack is up to the architecture.',
	"00000000-0000-0000-0000-000000000000");
